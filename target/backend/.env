# ─── Application ─────────────────────────────────────────────────────────────
# Source: config/settings.py :: DEBUG / WSGI_APPLICATION
NODE_ENV=development
PORT=3001

# ─── Security — JWT ───────────────────────────────────────────────────────────
# Source: config/settings.py :: SECRET_KEY
# MANDATORY in production — never use a hardcoded default.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=django-insecure-2jr-1j1%i(%pqej_8_ujp9l2n1vl%^i9y390o^n&nj_(z8!+ke

# ─── Database ─────────────────────────────────────────────────────────────────
# Source: config/settings.py :: DATABASE_URL conditional logic
#   SQLite dev/test : leave empty (auto file-based ./db.sqlite3)
#                  or DATABASE_URL=:memory: for in-memory tests
#   PostgreSQL prod : postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ─── CORS / Allowed Origins ───────────────────────────────────────────────────
# Source: config/settings.py :: ALLOWED_HOSTS (["*"] when DEBUG, list otherwise)
# Semicolon-separated list of allowed frontend origins.
# Empty = allow all (development only — mirrors Django DEBUG=True wildcard).
# Example: http://localhost:4200;https://conduit.example.com
ALLOWED_ORIGINS=http://localhost:4200

# ─── Password Hashing ─────────────────────────────────────────────────────────
# HV-002 decision (2026-04-15): PBKDF2 compatible Django — no bcrypt.
# Format: pbkdf2_sha256$<iterations>$<salt>$<hash_base64>
# Default matches Django 5.2 default (260000 iterations).
# Use PBKDF2_ITERATIONS=1 in tests (mirrors Django USE_FAST_HASHER=True).
PBKDF2_ITERATIONS=260000
